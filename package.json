{
	"name": "orsjo-website",
	"version": "0.2.0",
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"dev": "NEXT_PUBLIC_DATOCMS_ENVIRONMENT=dev next dev --turbo & npm run codegen",
		"build": "npm run prebuild && next build --turbo",
		"start": "next start",
		"preview": "npm run build && npm run start",
		"lint": "next lint",
		"prebuild": "tsx prebuild",
		"reset": "rm -rf ./node_modules && rm -rf pnpm-lock.yaml && rm -rf .next && pnpm i",
		"codegen": "chokidar \"./graphql/**/*.gql\" -c \"pnpm codegen:website\" & chokidar \"./lib/shopify/graphql/**/*.gql\" -c \"pnpm codegen:shopify\" & chokidar \"./lib/shopify/graphql-admin//**/*.gql\" -c \"pnpm codegen:shopify_admin\"",
		"codegen:website": "graphql-codegen --config graphql.config.ts --project default",
		"codegen:shopify": "graphql-codegen --config graphql.config.ts --project shopify",
		"codegen:shopify_admin": "graphql-codegen --config graphql.config.ts --project shopify_admin",
		"codegen:datocms": "datocms schema:generate ./types/datocms-cma.ts",
		"shopify:sync": "tsx lib/shopify/scripts/sync-item.ts",
		"shopify:sync-all": "tsx lib/shopify/scripts/sync-all.ts"
	},
	"dependencies": {
		"@datocms/cma-client": "^5.1.26",
		"@datocms/cma-client-browser": "^5.1.26",
		"@datocms/cma-client-node": "^5.1.26",
		"@react-email/components": "0.0.38",
		"@sentry/nextjs": "^10.19.0",
		"@sparticuz/chromium": "^141.0.0",
		"@sparticuz/chromium-min": "^137.0.1",
		"@svgr/webpack": "^8.1.0",
		"@types/react": "^19.1.2",
		"chokidar-cli": "^3.0.0",
		"classnames": "^2.5.1",
		"cookies-next": "^5.1.0",
		"date-fns": "^4.1.0",
		"datocms-structured-text-utils": "^5.0.0",
		"dotenv": "^16.5.0",
		"email-validator": "^2.0.4",
		"graphql": "^16.8.1",
		"hamburger-react": "^2.5.2",
		"mjml": "^4.15.3",
		"mjml-react": "^2.0.8",
		"next": "^15.5.6",
		"next-dato-utils": "github:bebejane/next-dato-utils#latest",
		"next-intl": "^4.4.0",
		"nextjs-google-analytics": "^2.3.7",
		"nodemailer": "^7.0.2",
		"puppeteer-core": "^24.29.0",
		"react": "19.1.0",
		"react-animate-height": "^3.2.3",
		"react-aria-components": "^1.10.0",
		"react-datocms": "^8.0.0-1",
		"react-dom": "19.1.0",
		"react-email": "^4.0.11",
		"react-hook-form": "^7.56.2",
		"react-icons": "^5.5.0",
		"react-intersection-observer": "^9.16.0",
		"react-use": "^17.6.0",
		"react-wrap-balancer": "^1.1.1",
		"rooks": "^8.0.1",
		"sass": "^1.87.0",
		"shopify-api-node": "^3.15.0",
		"swiper": "^11.2.8",
		"thenby": "^1.3.4",
		"tsx": "^4.20.6",
		"usehooks-ts": "^3.1.1",
		"zod": "^3.22.4",
		"zustand": "^5.0.4"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^6.0.1",
		"@graphql-codegen/typed-document-node": "^6.0.2",
		"@graphql-codegen/typescript": "^5.0.2",
		"@graphql-codegen/typescript-document-nodes": "^5.0.2",
		"@graphql-codegen/typescript-graphql-files-modules": "^3.0.1",
		"@graphql-codegen/typescript-operations": "^5.0.2",
		"@parcel/watcher": "^2.5.1",
		"@types/mjml-react": "^2.0.10",
		"@types/node": "^22.15.3",
		"@types/nodemailer": "^6.4.17",
		"@types/react-dom": "^19.1.3",
		"eslint": "9.26.0",
		"eslint-config-next": "15.3.1",
		"puppeteer": "^24.29.0",
		"xlsx-stream-reader": "^1.1.1"
	}
}
