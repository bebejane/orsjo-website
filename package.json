{
  "name": "orsjo-website",
  "version": "0.2.0",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo & pnpm run codegen",
    "dev:email": "email dev",
    "start": "next start",
    "build": "pnpm run prebuild && next build --turbo",
    "prebuild": "tsx prebuild",
    "postinstall": "node lib/scripts/postinstall.mjs",
    "preview": "pnpm run build && pnpm run start",
    "lint": "next lint",
    "reset": "rm -rf ./node_modules && rm -rf pnpm-lock.yaml && rm -rf .next && pnpm i",
    "codegen": "chokidar \"./graphql/**/*.gql\" -c \"pnpm codegen:website\" & chokidar \"./geins/graphql/**/*.gql\" -c \"pnpm codegen:geins\"",
    "codegen:website": "graphql-codegen --config graphql.config.ts --project datocms --verbose",
    "codegen:geins": "graphql-codegen --config graphql.config.ts --project geins --verbose",
    "codegen:datocms": "datocms schema:generate ./types/datocms-cma.d.ts",
    "codegen:datocms:dev": "datocms schema:generate -e=dev ./types/datocms-cma.d.ts",
    "geins:sync": "tsx geins/scripts/sync-item.ts",
    "geins:sync-all": "tsx geins/scripts/sync-all.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@datocms/cma-client": "^5.3.0",
    "@datocms/cma-client-browser": "^5.3.0",
    "@datocms/cma-client-node": "^5.3.0",
    "@datocms/content-link": "^0.3.18",
    "@geins/core": "^0.6.1",
    "@geins/oms": "^0.6.1",
    "@mux/mux-player-react": "^3.11.4",
    "@next/third-parties": "^16.2.6",
    "@react-email/components": "0.0.38",
    "@react-email/preview-server": "^5.2.8",
    "@sentry/nextjs": "^10.48.0",
    "@sparticuz/chromium-min": "^143.0.4",
    "@svgr/webpack": "^8.1.0",
    "@types/react": "^19.2.14",
    "@vercel/functions": "^3.4.3",
    "@vercel/stega": "^1.0.0",
    "chalk": "^5.6.2",
    "classnames": "^2.5.1",
    "client-zip": "^2.5.0",
    "cookies-next": "^5.1.0",
    "date-fns": "^4.1.0",
    "datocms-structured-text-utils": "^5.1.7",
    "dotenv": "^17.3.1",
    "google": "link:@next/third-parties/google",
    "graphql": "^16.13.0",
    "hamburger-react": "^2.5.2",
    "isbot": "^5.1.35",
    "next": "^16.2.3",
    "next-dato-utils": "github:bebejane/next-dato-utils",
    "next-intl": "^4.8.3",
    "nextjs-google-analytics": "^2.3.7",
    "pdf-lib": "^1.17.1",
    "postmark": "^4.0.7",
    "puppeteer-core": "^24.40.0",
    "react": "^19.2.3",
    "react-animate-height": "^3.2.3",
    "react-aria-components": "^1.16.0",
    "react-balance-text": "^2.0.1",
    "react-datocms": "^8.0.0",
    "react-dom": "^19.2.3",
    "react-dropzone": "^15.0.0",
    "react-facebook-pixel": "^1.0.4",
    "react-hook-form": "^7.56.2",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-use": "^17.6.0",
    "react-wrap-balancer": "^1.1.1",
    "read-excel-file": "^8.0.3",
    "rooks": "^8.0.1",
    "sass": "^1.87.0",
    "swiper": "^12.1.3",
    "thenby": "^1.3.4",
    "usehooks-ts": "^3.1.1",
    "zod": "^3.22.4",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@geins/types": "^0.6.1",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/typed-document-node": "^6.0.2",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-document-nodes": "^5.0.2",
    "@graphql-codegen/typescript-graphql-files-modules": "^3.0.1",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@parcel/watcher": "^2.5.6",
    "@sparticuz/chromium": "^141.0.0",
    "@types/node": "^22.15.3",
    "@types/react-dom": "^19.2.0",
    "baseline-browser-mapping": "^2.10.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "9.26.0",
    "eslint-config-next": "15.3.1",
    "puppeteer": "^24.40.0",
    "react-email": "^5.0.5",
    "tsx": "^4.20.6",
    "xlsx-stream-reader": "^1.1.1"
  }
}